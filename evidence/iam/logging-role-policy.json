{
  "firehose_delivery_role": {
    "role_name": "security-log-delivery-firehose-delivery-role",
    "policy_name": "security-log-delivery-firehose-delivery-policy",
    "policy_document": {
      "Version": "2012-10-17",
      "Statement": [
        {
          "Action": [
            "s3:AbortMultipartUpload",
            "s3:GetBucketLocation",
            "s3:GetObject",
            "s3:ListBucket",
            "s3:ListBucketMultipartUploads",
            "s3:PutObject"
          ],
          "Effect": "Allow",
          "Resource": [
            "arn:aws:s3:::central-security-log-archive-725644097230-us-east-1",
            "arn:aws:s3:::central-security-log-archive-725644097230-us-east-1/firehose/752575507725/*"
          ],
          "Sid": "AllowS3Delivery"
        },
        {
          "Action": [
            "kms:Decrypt",
            "kms:DescribeKey",
            "kms:Encrypt",
            "kms:GenerateDataKey*"
          ],
          "Effect": "Allow",
          "Resource": "arn:aws:kms:us-east-1:725644097230:key/65633ecd-2eb0-4301-aaa1-3696409cbbc2",
          "Sid": "AllowKmsUsage"
        },
        {
          "Action": [
            "logs:PutLogEvents"
          ],
          "Effect": "Allow",
          "Resource": "arn:aws:logs:us-east-1:725644097230:log-group:/aws/firehose/security-log-delivery:log-stream:delivery",
          "Sid": "AllowFirehoseCloudWatchLogging"
        }
      ]
    }
  },
  "cloudwatch_to_firehose_role": {
    "role_name": "security-log-delivery-cloudwatch-to-firehose-role",
    "policy_name": "security-log-delivery-cloudwatch-to-firehose-policy",
    "policy_document": {
      "Version": "2012-10-17",
      "Statement": [
        {
          "Action": [
            "firehose:PutRecord",
            "firehose:PutRecordBatch"
          ],
          "Effect": "Allow",
          "Resource": "arn:aws:firehose:us-east-1:725644097230:deliverystream/security-log-delivery",
          "Sid": "AllowCloudWatchLogsToWriteToFirehose"
        }
      ]
    }
  }
}
