{
  "component-definition": {
    "uuid": "6a0d3757-9dd5-49df-bc8a-db1d02f0cd72",
    "metadata": {
      "title": "Centralized Logging and Monitoring System",
      "version": "1.1.0",
      "oscal-version": "1.1.2",
      "last-modified": "2026-04-29T00:00:00Z"
    },
    "components": [
      {
        "uuid": "b0f3a3a6-5d9a-4f47-9c6e-2a45d03d0f91",
        "type": "service",
        "title": "Centralized Logging and Monitoring",
        "description": "AWS-based centralized logging, monitoring, and audit system using CloudTrail, CloudWatch Logs, Firehose, S3, KMS, GuardDuty, and Detective.",
        "control-implementations": [
          {
            "source": "NIST-800-53",
            "implemented-requirements": [

              {
                "control-id": "AU-2",
                "description": "Audit events are generated.",
                "props": [
                  { "name": "evidence", "value": "cloudtrail/org-trail-config.json" }
                ]
              },

              {
                "control-id": "AU-3",
                "description": "Audit records contain sufficient information.",
                "props": [
                  { "name": "evidence", "value": "cloudtrail/event-selectors.json" }
                ]
              },

              {
                "control-id": "AU-6",
                "description": "Audit review and analysis is performed.",
                "props": [
                  { "name": "evidence", "value": "monitoring/cloudwatch-alarms.json" },
                  { "name": "evidence", "value": "monitoring/log-delivery-metrics.json" }
                ]
              },

              {
                "control-id": "AU-8",
                "description": "Audit records include timestamps.",
                "props": [
                  { "name": "evidence", "value": "cloudtrail/org-trail-config.json" }
                ]
              },

              {
                "control-id": "AU-9",
                "description": "Audit information is protected.",
                "props": [
                  { "name": "evidence", "value": "s3/object-lock-config.json" },
                  { "name": "evidence", "value": "s3/central-security-logs-policy.json" }
                ]
              },

              {
                "control-id": "AU-11",
                "description": "Audit retention enforced.",
                "props": [
                  { "name": "evidence", "value": "s3/bucket-lifecycle.json" }
                ]
              },

              {
                "control-id": "AU-12",
                "description": "Audit records are generated and transmitted.",
                "props": [
                  { "name": "evidence", "value": "firehose/security-log-delivery.json" },
                  { "name": "evidence", "value": "cloudwatch/destination-policy.json" }
                ]
              },

              {
                "control-id": "AC-3",
                "description": "Access enforcement on logging resources.",
                "props": [
                  { "name": "evidence", "value": "iam/logging-role-policy.json" },
                  { "name": "evidence", "value": "iam/trust-policy.json" }
                ]
              },

              {
                "control-id": "CM-2",
                "description": "Baseline configuration is defined.",
                "props": [
                  { "name": "evidence", "value": "monitoring/config-rules.json" }
                ]
              },

              {
                "control-id": "CM-6",
                "description": "Configuration settings enforced.",
                "props": [
                  { "name": "evidence", "value": "monitoring/config-rules.json" }
                ]
              },

              {
                "control-id": "SI-4",
                "description": "System monitoring is implemented.",
                "props": [
                  { "name": "evidence", "value": "guardduty/detector-config.json" },
                  { "name": "evidence", "value": "detective/graph-config.json" }
                ]
              },

              {
                "control-id": "SI-7",
                "description": "Integrity protection for logs.",
                "props": [
                  { "name": "evidence", "value": "s3/object-lock-config.json" }
                ]
              },

              {
                "control-id": "SC-12",
                "description": "Cryptographic key management.",
                "props": [
                  { "name": "evidence", "value": "kms/key-metadata.json" },
                  { "name": "evidence", "value": "kms/key-rotation-status.json" }
                ]
              },

              {
                "control-id": "SC-28",
                "description": "Protection of data at rest.",
                "props": [
                  { "name": "evidence", "value": "s3/bucket-encryption.json" }
                ]
              }

            ]
          }
        ]
      }
    ]
  }
}
