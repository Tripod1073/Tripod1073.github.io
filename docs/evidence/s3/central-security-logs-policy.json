{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "DenyInsecureTransport",
      "Effect": "Deny",
      "Principal": "*",
      "Action": "s3:*",
      "Resource": [
        "arn:aws:s3:::central-security-log-archive-725644097230-us-east-1/*",
        "arn:aws:s3:::central-security-log-archive-725644097230-us-east-1"
      ],
      "Condition": {
        "Bool": {
          "aws:SecureTransport": "false"
        }
      }
    },
    {
      "Sid": "DenyNonKMSEncryption",
      "Effect": "Deny",
      "Principal": "*",
      "Action": "s3:PutObject",
      "Resource": "arn:aws:s3:::central-security-log-archive-725644097230-us-east-1/*",
      "Condition": {
        "StringNotEqualsIfExists": {
          "s3:x-amz-server-side-encryption": "aws:kms"
        },
        "Null": {
          "s3:x-amz-server-side-encryption": "false"
        }
      }
    },
    {
      "Sid": "AllowCloudTrailAclCheck",
      "Effect": "Allow",
      "Principal": {
        "Service": "cloudtrail.amazonaws.com"
      },
      "Action": "s3:GetBucketAcl",
      "Resource": "arn:aws:s3:::central-security-log-archive-725644097230-us-east-1",
      "Condition": {
        "StringEquals": {
          "aws:SourceAccount": [
            "725644097230",
            "752575507725",
            "655916713994"
          ]
        },
        "ArnLike": {
          "aws:SourceArn": "arn:aws:cloudtrail:us-east-1:655916713994:trail/enterprise-organization-trail-security"
        }
      }
    },
    {
      "Sid": "AllowCloudTrailWrite",
      "Effect": "Allow",
      "Principal": {
        "Service": "cloudtrail.amazonaws.com"
      },
      "Action": "s3:PutObject",
      "Resource": [
        "arn:aws:s3:::central-security-log-archive-725644097230-us-east-1/AWSLogs/o-5uqxxe8fif/*",
        "arn:aws:s3:::central-security-log-archive-725644097230-us-east-1/AWSLogs/752575507725/*",
        "arn:aws:s3:::central-security-log-archive-725644097230-us-east-1/AWSLogs/725644097230/*",
        "arn:aws:s3:::central-security-log-archive-725644097230-us-east-1/AWSLogs/655916713994/*"
      ],
      "Condition": {
        "StringEquals": {
          "s3:x-amz-acl": "bucket-owner-full-control",
          "aws:SourceAccount": [
            "725644097230",
            "752575507725",
            "655916713994"
          ]
        },
        "ArnLike": {
          "aws:SourceArn": "arn:aws:cloudtrail:us-east-1:655916713994:trail/enterprise-organization-trail-security"
        }
      }
    },
    {
      "Sid": "AllowFirehoseWrite",
      "Effect": "Allow",
      "Principal": {
        "Service": "firehose.amazonaws.com"
      },
      "Action": [
        "s3:PutObject",
        "s3:ListBucketMultipartUploads",
        "s3:ListBucket",
        "s3:GetBucketLocation",
        "s3:AbortMultipartUpload"
      ],
      "Resource": [
        "arn:aws:s3:::central-security-log-archive-725644097230-us-east-1/firehose/752575507725/*",
        "arn:aws:s3:::central-security-log-archive-725644097230-us-east-1"
      ],
      "Condition": {
        "ForAnyValue:StringEquals": {
          "aws:SourceAccount": "752575507725"
        }
      }
    },
    {
      "Sid": "AllowVpcFlowLogsDiscovery",
      "Effect": "Allow",
      "Principal": {
        "Service": "delivery.logs.amazonaws.com"
      },
      "Action": [
        "s3:ListBucket",
        "s3:GetBucketAcl"
      ],
      "Resource": "arn:aws:s3:::central-security-log-archive-725644097230-us-east-1",
      "Condition": {
        "ForAnyValue:StringEquals": {
          "aws:SourceAccount": "752575507725"
        }
      }
    },
    {
      "Sid": "AllowVpcFlowLogsWrite",
      "Effect": "Allow",
      "Principal": {
        "Service": "delivery.logs.amazonaws.com"
      },
      "Action": "s3:PutObject",
      "Resource": "arn:aws:s3:::central-security-log-archive-725644097230-us-east-1/vpc-flow-logs/752575507725/*",
      "Condition": {
        "ForAnyValue:StringEquals": {
          "aws:SourceAccount": "752575507725"
        },
        "ForAnyValue:ArnLike": {
          "aws:SourceArn": [
            "arn:aws:route53resolver:us-east-1:725644097230:resolver-query-log-config/rqlc-c7ac50a67cbd4a06",
            "arn:aws:logs:us-east-1:752575507725:*",
            "arn:aws:ec2:us-east-1:752575507725:vpc/vpc-02b1bbd8c2a0e10bc",
            "arn:aws:ec2:us-east-1:752575507725:vpc/vpc-053792d8cae24ebbd",
            "arn:aws:ec2:us-east-1:752575507725:vpc/vpc-0477d91b5413cd0de"
          ]
        }
      }
    },
    {
      "Sid": "AllowRoute53ResolverLogsDiscovery",
      "Effect": "Allow",
      "Principal": {
        "Service": "delivery.logs.amazonaws.com"
      },
      "Action": [
        "s3:ListBucket",
        "s3:GetBucketAcl"
      ],
      "Resource": "arn:aws:s3:::central-security-log-archive-725644097230-us-east-1",
      "Condition": {
        "ForAnyValue:StringEquals": {
          "aws:SourceAccount": "752575507725"
        }
      }
    },
    {
      "Sid": "AllowRoute53ResolverLogsWrite",
      "Effect": "Allow",
      "Principal": {
        "Service": "delivery.logs.amazonaws.com"
      },
      "Action": "s3:PutObject",
      "Resource": "arn:aws:s3:::central-security-log-archive-725644097230-us-east-1/route53-query-logs/752575507725/*",
      "Condition": {
        "ForAnyValue:StringEquals": {
          "aws:SourceAccount": "752575507725"
        },
        "ForAnyValue:ArnLike": {
          "aws:SourceArn": [
            "arn:aws:route53resolver:us-east-1:725644097230:resolver-query-log-config/rqlc-c7ac50a67cbd4a06",
            "arn:aws:logs:us-east-1:752575507725:*",
            "arn:aws:ec2:us-east-1:752575507725:vpc/vpc-02b1bbd8c2a0e10bc",
            "arn:aws:ec2:us-east-1:752575507725:vpc/vpc-053792d8cae24ebbd",
            "arn:aws:ec2:us-east-1:752575507725:vpc/vpc-0477d91b5413cd0de"
          ]
        }
      }
    }
  ]
}
