{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "AllowRootAccountAdministration",
      "Effect": "Allow",
      "Principal": {
        "AWS": "arn:aws:iam::725644097230:root"
      },
      "Action": "kms:*",
      "Resource": "*"
    },
    {
      "Sid": "AllowCloudTrailEncrypt",
      "Effect": "Allow",
      "Principal": {
        "Service": "cloudtrail.amazonaws.com"
      },
      "Action": [
        "kms:GenerateDataKey*",
        "kms:Encrypt",
        "kms:DescribeKey"
      ],
      "Resource": "*",
      "Condition": {
        "ForAnyValue:StringEquals": {
          "aws:SourceArn": "arn:aws:cloudtrail:us-east-1:655916713994:trail/enterprise-organization-trail-security"
        },
        "ForAnyValue:StringLike": {
          "kms:EncryptionContext:aws:cloudtrail:arn": [
            "arn:aws:cloudtrail:*:725644097230:trail/*",
            "arn:aws:cloudtrail:*:752575507725:trail/*",
            "arn:aws:cloudtrail:*:655916713994:trail/*"
          ]
        }
      }
    },
    {
      "Sid": "AllowCloudTrailDecryptForAuthorizedAccounts",
      "Effect": "Allow",
      "Principal": {
        "AWS": [
          "arn:aws:iam::655916713994:root",
          "arn:aws:iam::752575507725:root",
          "arn:aws:iam::725644097230:root"
        ]
      },
      "Action": [
        "kms:ReEncryptTo",
        "kms:ReEncryptFrom",
        "kms:GenerateDataKey*",
        "kms:DescribeKey",
        "kms:Decrypt"
      ],
      "Resource": "*",
      "Condition": {
        "ForAnyValue:StringLike": {
          "kms:EncryptionContext:aws:cloudtrail:arn": [
            "arn:aws:cloudtrail:*:725644097230:trail/*",
            "arn:aws:cloudtrail:*:752575507725:trail/*",
            "arn:aws:cloudtrail:*:655916713994:trail/*"
          ]
        }
      }
    },
    {
      "Sid": "AllowFirehoseEncrypt",
      "Effect": "Allow",
      "Principal": {
        "Service": "firehose.amazonaws.com"
      },
      "Action": [
        "kms:GenerateDataKey",
        "kms:Encrypt",
        "kms:DescribeKey"
      ],
      "Resource": "*",
      "Condition": {
        "ForAnyValue:StringEquals": {
          "aws:SourceAccount": "752575507725"
        }
      }
    },
    {
      "Sid": "AllowLogsDeliveryEncrypt",
      "Effect": "Allow",
      "Principal": {
        "Service": "delivery.logs.amazonaws.com"
      },
      "Action": [
        "kms:ReEncrypt*",
        "kms:GenerateDataKey*",
        "kms:Encrypt",
        "kms:DescribeKey",
        "kms:Decrypt"
      ],
      "Resource": "*",
      "Condition": {
        "ForAnyValue:StringEquals": {
          "aws:SourceAccount": "752575507725"
        },
        "ForAnyValue:ArnLike": {
          "aws:SourceArn": [
            "arn:aws:route53resolver:us-east-1:725644097230:resolver-query-log-config/rqlc-c7ac50a67cbd4a06",
            "arn:aws:logs:us-east-1:752575507725:*",
            "arn:aws:ec2:us-east-1:752575507725:vpc/vpc-02b1bbd8c2a0e10bc",
            "arn:aws:ec2:us-east-1:752575507725:vpc/vpc-053792d8cae24ebbd",
            "arn:aws:ec2:us-east-1:752575507725:vpc/vpc-0477d91b5413cd0de"
          ]
        }
      }
    },
    {
      "Sid": "AllowCloudWatchLogsEncrypt",
      "Effect": "Allow",
      "Principal": {
        "Service": "logs.us-east-1.amazonaws.com"
      },
      "Action": [
        "kms:ReEncrypt*",
        "kms:GenerateDataKey*",
        "kms:Encrypt",
        "kms:DescribeKey",
        "kms:Decrypt"
      ],
      "Resource": "*",
      "Condition": {
        "ArnLike": {
          "kms:EncryptionContext:aws:logs:arn": "arn:aws:logs:us-east-1:725644097230:*"
        }
      }
    },
    {
      "Sid": "AllowConfigEncrypt",
      "Effect": "Allow",
      "Principal": {
        "Service": "config.amazonaws.com"
      },
      "Action": [
        "kms:GenerateDataKey",
        "kms:Decrypt"
      ],
      "Resource": "*",
      "Condition": {
        "StringEquals": {
          "aws:SourceAccount": "725644097230"
        }
      }
    }
  ]
}
