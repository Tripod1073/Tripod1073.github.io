{
  "firehose_delivery_role": {
    "role_name": "security-log-delivery-firehose-delivery-role",
    "assume_role_policy_document": {
      "Version": "2012-10-17",
      "Statement": [
        {
          "Sid": "AllowFirehoseServiceAssume",
          "Effect": "Allow",
          "Principal": {
            "Service": "firehose.amazonaws.com"
          },
          "Action": "sts:AssumeRole"
        }
      ]
    }
  },
  "cloudwatch_to_firehose_role": {
    "role_name": "security-log-delivery-cloudwatch-to-firehose-role",
    "assume_role_policy_document": {
      "Version": "2012-10-17",
      "Statement": [
        {
          "Sid": "AllowCloudWatchLogsDestinationService",
          "Effect": "Allow",
          "Principal": {
            "Service": "logs.amazonaws.com"
          },
          "Action": "sts:AssumeRole"
        }
      ]
    }
  }
}
